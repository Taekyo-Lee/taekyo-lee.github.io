---
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../consts';

interface Props {
	current?: string;
}
const { current } = Astro.props;
const base = import.meta.env.BASE_URL;

const posts = await getCollection('blog');
const counts = posts.reduce<Record<string, number>>((acc, p) => {
	acc[p.data.category] = (acc[p.data.category] ?? 0) + 1;
	return acc;
}, {});

const items = Object.keys(CATEGORY_LABELS)
	.filter((slug) => (counts[slug] ?? 0) > 0)
	.map((slug) => ({
		slug,
		label: CATEGORY_LABELS[slug],
		count: counts[slug] ?? 0,
		href: `${base}category/${slug}/`,
	}));

const totalCount = posts.length;
const allActive = !current;
---

<aside class="sidebar">
	<h3 class="heading">Categories</h3>
	<ul class="list">
		<li>
			<a href={`${base}blog/`} class:list={['item', { active: allActive }]}>
				<span class="label">All</span>
				<span class="count">{totalCount}</span>
			</a>
		</li>
		{
			items.map((item) => (
				<li>
					<a
						href={item.href}
						class:list={['item', `cat-${item.slug}`, { active: current === item.slug }]}
					>
						<span class="label">{item.label}</span>
						<span class="count">{item.count}</span>
					</a>
				</li>
			))
		}
	</ul>
</aside>

<style>
	.sidebar {
		position: sticky;
		top: 1em;
		align-self: start;
	}
	.heading {
		margin: 0 0 0.75em 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	.list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.15em;
	}
	.item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.45em 0.7em;
		border-radius: 8px;
		font-size: 0.92rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.item:hover {
		background: rgb(var(--gray-light), 0.6);
		color: rgb(var(--black));
	}
	.item.active {
		background: var(--cat-bg, rgb(var(--accent), 0.1));
		color: var(--cat-fg, var(--accent));
		font-weight: 600;
	}
	.count {
		font-size: 0.78rem;
		color: rgb(var(--gray));
		font-variant-numeric: tabular-nums;
	}
	.item.active .count {
		color: var(--cat-fg, var(--accent));
	}
	@media (max-width: 720px) {
		.sidebar {
			position: static;
		}
		.list {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.4em;
		}
		.item {
			padding: 0.35em 0.7em;
			background: rgb(var(--gray-light), 0.5);
		}
		.count {
			margin-left: 0.4em;
		}
	}
</style>
