---
const isCompany = import.meta.env.PUBLIC_IS_COMPANY === 'true';
const companyDiscussionsUrl =
	'https://github.samsungds.net/aiagent/ai-native-development-blog/discussions';
---

{isCompany ? (
	<section class="giscus-wrap" aria-label="Comments">
		<h2 class="giscus-heading">댓글</h2>
		<p class="company-note">
			사내 환경에서는 댓글이 GitHub Discussions 에서 진행됩니다.
		</p>
		<a
			class="company-link"
			href={companyDiscussionsUrl}
			target="_blank"
			rel="noopener noreferrer"
		>
			GitHub Discussions 에서 의견 남기기 →
		</a>
	</section>
) : (
	<section class="giscus-wrap" aria-label="Comments">
		<h2 class="giscus-heading">댓글</h2>
		<script
			src="https://giscus.app/client.js"
			data-repo="Taekyo-Lee/taekyo-lee.github.io"
			data-repo-id="R_kgDOSE0K-w"
			data-category="Announcements"
			data-category-id="DIC_kwDOSE0K-84C8HnA"
			data-mapping="pathname"
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="0"
			data-input-position="bottom"
			data-theme="preferred_color_scheme"
			data-lang="ko"
			crossorigin="anonymous"
			async
		/>
	</section>
)}

<style>
	.giscus-wrap {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.giscus-heading {
		margin: 0 0 1em 0;
		font-size: 1.25em;
		color: rgb(var(--black));
	}
	.company-note {
		margin: 0 0 1em 0;
		color: rgb(var(--gray-dark));
		font-size: 0.95em;
	}
	.company-link {
		display: inline-block;
		padding: 0.6em 1.2em;
		background: rgba(31, 71, 135, 0.06);
		border: 1px solid rgba(31, 71, 135, 0.18);
		border-radius: 8px;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		transition: background 0.2s;
	}
	.company-link:hover {
		background: rgba(31, 71, 135, 0.12);
	}
</style>
